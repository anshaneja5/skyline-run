# GitHub personal access token (classic). `read:user` scope is enough.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Username pre-filled on the start screen
DEFAULT_USER=anshaneja5

# Backend port (frontend proxies /api here)
PORT=3001

# Optional: Upstash Redis for the global leaderboard (console.upstash.com).
# Without these the leaderboard uses a non-persistent in-memory store.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
